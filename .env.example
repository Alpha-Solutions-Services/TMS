# Alpha Freight Network TMS
NEXT_PUBLIC_TMS_URL=https://your-tms-domain.example
NEXT_PUBLIC_SITE_URL=https://your-site-domain.example

# Supabase (same project as Portal)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# Super dispatchers (comma-separated) — full access + approval queue
# Env list = bootstrap supers; add more via tms_users (role: super_dispatcher or sub_dispatcher)
SUPER_DISPATCHER_EMAILS=super1@example.com,super2@example.com

# Optional SMTP for notifications (Phase 2)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-app-password-here
SMTP_FROM=Alpha Freight Network <alphaassistant.alpha@gmail.com>
AUTH_OPS_NOTIFY_EMAIL=alphaassistant.alpha@gmail.com
# Public contact shown to carriers (not SMTP From)
FREIGHT_SUPPORT_EMAIL=support@freight.alphasolutions.software
FREIGHT_TEAM_EMAIL=alphaassistant.alpha@gmail.com

# Groq AI — load board paste parsing + freight assistant
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview
